# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# Full URL to a Cal.com or Calendly booking page (optional).
# NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/your-org/30min

# Shown in mailto links and fallback copy when no scheduler URL is set.
# NEXT_PUBLIC_SALES_EMAIL=you@yourdomain.com
